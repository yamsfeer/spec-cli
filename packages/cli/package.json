{
  "name": "spec-cli",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "spec-cli": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "@spec-cli/agents": "workspace:*",
    "@spec-cli/core": "workspace:*",
    "@spec-cli/shared": "workspace:*",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "fs-extra": "^11.2.0",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "zod": "^3.24.0"
  }
}
