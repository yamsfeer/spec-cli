{
  "name": "@spec-cli/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@spec-cli/shared": "workspace:*",
    "fs-extra": "^11.2.0",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "chokidar": "^4.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.0"
  }
}
